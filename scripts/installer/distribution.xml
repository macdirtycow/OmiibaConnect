<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Omiiba Connect</title>
    <organization>dev.omiiba</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <choices-outline>
        <line choice="default">
            <line choice="dev.omiiba.connect.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="dev.omiiba.connect.pkg" visible="false">
        <pkg-ref id="dev.omiiba.connect.pkg"/>
    </choice>
    <pkg-ref id="dev.omiiba.connect.pkg" version="VERSION_PLACEHOLDER" onConclusion="none">OmiibaConnect-component.pkg</pkg-ref>
</installer-gui-script>
